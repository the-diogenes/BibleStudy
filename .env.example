# Optional alternative to public/config.js for local dev / CI builds.
# If public/config.js is present, it takes precedence over these values.

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
VITE_GROUP_NAME=Our Bible Study

# For GitHub Pages PROJECT sites only (username.github.io/<repo>/), set the base
# path used by the build. Leave unset for local dev or a user/org page.
# VITE_BASE=/bible-study/
